# =============================================================================
# AATDRS – Environment Variables Template
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=change_me_strong_password
DB_NAME=roster_db
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_char_hex_secret
JWT_REFRESH_SECRET=replace_with_another_64_char_hex_secret

# ── Override Audit HMAC ───────────────────────────────────────────────────────
OVERRIDE_HMAC_SECRET=replace_with_override_hmac_secret

# ── Application ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
